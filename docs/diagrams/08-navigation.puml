@startuml
' 图说明：本图展示 Android 客户端主要页面之间的导航关系。
skinparam shadowing false
skinparam packageStyle rectangle

title TPS 安卓页面导航图

rectangle "启动入口" {
  [登录页]
  [注册页]
}

rectangle "普通用户主界面" {
  [首页商品列表]
  [消息列表]
  [个人中心]
}

rectangle "普通用户功能页" {
  [商品详情页]
  [聊天页]
  [发布商品页]
  [我的商品]
  [我的收藏]
  [浏览历史]
  [用户反馈]
}

rectangle "管理员主界面" {
  [管理员-用户]
  [管理员-商品]
  [管理员-订单]
  [管理员-统计]
}

[登录页] --> [注册页] : 去注册
[注册页] --> [登录页] : 注册成功返回

[登录页] --> [首页商品列表] : 普通用户
[登录页] --> [管理员-用户] : 管理员

[首页商品列表] --> [商品详情页]
[首页商品列表] --> [发布商品页]
[消息列表] --> [聊天页]
[个人中心] --> [我的商品]
[个人中心] --> [我的收藏]
[个人中心] --> [浏览历史]
[个人中心] --> [用户反馈]
[我的商品] --> [商品详情页]
[我的收藏] --> [商品详情页]
[浏览历史] --> [商品详情页]
[商品详情页] --> [聊天页]

[管理员-用户] --> [管理员-商品]
[管理员-商品] --> [管理员-订单]
[管理员-订单] --> [管理员-统计]

@enduml
